# Server
PORT=3001
NODE_ENV=development

# MongoDB — use Atlas for Vector Search support
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/vpo-assistant

# Anthropic — for ticket analysis and the assistant
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI — for embeddings (Anthropic recommends Voyage; no native Anthropic embeddings)
VOYAGE_API_KEY=pa-...

# Auth (replace with proper auth provider in production)
JWT_SECRET=change-me-in-production
